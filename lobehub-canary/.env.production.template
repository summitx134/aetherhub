# AetherHub Production Environment Template
# ==========================================
# Copy to .env.production and fill in all values before deployment.
# Generated: 2026-06-16

# ── Database ──────────────────────────────────
# PostgreSQL connection (required)
DATABASE_URL=postgres://user:password@host:5432/aetherhub
DATABASE_DRIVER=node

# ── Redis ────────────────────────────────────
REDIS_URL=redis://host:6379

# ── S3 Compatible Storage ────────────────────
# AWS S3, Cloudflare R2, or MinIO
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=https://your-bucket.s3.region.amazonaws.com
S3_BUCKET=aetherhub-prod
S3_REGION=us-west-1
S3_PUBLIC_DOMAIN=https://cdn.aetherhub.ai

# ── Auth ─────────────────────────────────────
# Better Auth OIDC (Google, GitHub, etc.)
# See: https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://api.aetherhub.ai

# ── AI Provider ──────────────────────────────
# Default AI backend (DeepSeek, OpenAI, Anthropic, etc.)
# AI_PROVIDER=deepseek
# AI_API_KEY=

# ── Optional Services ─────────────────────────
# For Upstash QStash (background jobs)
# QSTASH_TOKEN=
# For analytics/monitoring
# TELEMETRY_ENABLED=false

# ── Vite SPA Build ────────────────────────────
NODE_ENV=production
